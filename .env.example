# PostgreSQL
POSTGRES_PASSWORD=

# Auth
BETTER_AUTH_SECRET=
# Optional. If empty, docker-compose will reuse BETTER_AUTH_SECRET.
AUTH_SESSION_SECRET=
BETTER_AUTH_URL=https://yourdomain.com

# Google OAuth (required for Google sign-in)
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Helius
HELIUS_API_KEY=

# Ollama
# Use http://ollama:11434 when running the optional ollama service in docker-compose.
OLLAMA_BASE_URL=
OLLAMA_API_KEY=
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_MS=15000

# Solana RPC
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# CoinGecko
COINGECKO_API_KEY=

# API CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://yourdomain.com

# Hono backend URL (as seen by the browser)
# Local dev: http://localhost:8787
# Production: https://yourdomain.com/api/v1  (nginx strips /api/v1 prefix)
NEXT_PUBLIC_API_URL=https://yourdomain.com/api/v1

# Internal server-to-server URL (Next.js → Hono, never exposed to browser)
# Local dev: http://localhost:8787
# Docker: set automatically to http://api:8787 in docker-compose.yml
API_INTERNAL_URL=http://localhost:8787

# Shared secret for Next.js → Hono server-to-server calls
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=
