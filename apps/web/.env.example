# ── Database ──────────────────────────────────────────────────────────────────
# Production (PostgreSQL): postgresql://user:password@host:5432/dbname
# Local dev (SQLite): kosongkan, otomatis pakai data/auth.sqlite
DATABASE_URL=

# ── Better Auth ───────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
# Hanya dipakai kalau DATABASE_URL kosong (SQLite local dev)
AUTH_DB_PATH=

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Buat di: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Helius (Solana RPC) ────────────────────────────────────────────────────────
HELIUS_API_KEY=

# ── Ollama (LLM) ──────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_API_KEY=
OLLAMA_MODEL=your-ollama-model
OLLAMA_TIMEOUT_MS=15000

# ── Solana RPC (public, exposed to browser) ────────────────────────────────────
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ── CoinGecko ─────────────────────────────────────────────────────────────────
COINGECKO_API_KEY=
